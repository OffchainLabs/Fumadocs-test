    "inventory-links": "node scripts/inventory-links.mjs",
    "move-doc": "node scripts/move-doc.mjs",
    "check-links": "node scripts/check-links.mjs",
    "restructure": "node scripts/restructure.mjs",
    "partials:migrate": "node scripts/migrate-partials.mjs",
    "partials:catalog": "node scripts/generate-partials-catalog.mjs",
    "partials:check": "node scripts/partials-check.mjs",
    "glossary:migrate": "node scripts/migrate-glossary.mjs",
    "quicklooks:migrate": "node scripts/migrate-quicklooks.mjs",
    "references:check": "node scripts/references-check.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@ethersproject/address": "5.8.0",
    "@floating-ui/react": "0.27.19",
    "@mdx-js/react": "3.1.1",
    "fumadocs-core": "16.11.1",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-ui": "16.11.1",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@offchainlabs/prettier-config": "0.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@trivago/prettier-plugin-sort-imports": "5.2.2",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.14",
    "prettier": "3.9.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
