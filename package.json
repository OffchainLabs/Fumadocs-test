{
  "name": "Fumadocs-test",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "next build --experimental-build-mode=compile",
    "dev": "next dev",
